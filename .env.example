# Copy this file to .env and fill in real values. Never commit .env.

# Password required to open a terminal session. Pick something long and random.
TTY_PASSWORD=change-me-to-something-long-and-random

# Port the server listens on.
PORT=3000

# Shell to spawn for each session. Defaults to $SHELL on macOS/Linux
# or powershell.exe on Windows if left unset.
# TTY_SHELL=/bin/bash

# Directory each new session starts in. Defaults to the user's home directory.
# TTY_CWD=/home/youruser
